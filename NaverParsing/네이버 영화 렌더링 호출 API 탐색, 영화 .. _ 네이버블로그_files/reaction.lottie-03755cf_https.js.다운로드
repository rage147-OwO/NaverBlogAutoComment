/**
 * @param reactionQuerySelector - lottie를 생성해야하는 위치
 * @param funcLottieType - lottie element로부터 reaction type을 찾는 함수
 * @constructor
 */
var ReactionLottie = function(reactionQuerySelector, funcLottieType) {
    var lottieTypeMap = {
        "like": "/common/json/lottie/Emoji-01.json",
        "impressive": "/common/json/lottie/Emoji-02.json",
        "thanks": "/common/json/lottie/Emoji-03.json",
        "haha": "/common/json/lottie/Emoji-04.json",
        "wow": "/common/json/lottie/Emoji-05.json",
        "sad": "/common/json/lottie/Emoji-06.json"
    };

    window.lottieAnimationDataCache =  {};

    observer = new IntersectionObserver(function(entries) {
        entries.forEach(function (entry) {
            var faceType = funcLottieType(entry.target);

            if (entry.isIntersecting) {
                if (entry.target.lottie === undefined) {
                    if (lottieAnimationDataCache[faceType]) {
                        entry.target.lottie = lottie.loadAnimation({
                            container: entry.target,
                            renderer: 'svg',
                            loop: true,
                            autoplay: true,
                            animationData: lottieAnimationDataCache[faceType]
                        });
                    } else {
                        entry.target.lottie = lottie.loadAnimation({
                            container: entry.target,
                            renderer: 'svg',
                            loop: true,
                            autoplay: true,
                            path: lottieTypeMap[faceType]
                        });
                    }

                    entry.target.lottie.addEventListener('data_ready', function () {
                        lottieAnimationDataCache[faceType] = entry.target.lottie.animationData;
                    });
                }

                entry.target.lottie.play();
            } else {
                if (entry.target.lottie === undefined) {
                    return;
                }

                entry.target.lottie.stop();
            }
        });
    });

    document.querySelectorAll(reactionQuerySelector).forEach(function(element) {
        observer.observe(element);
    });
};
